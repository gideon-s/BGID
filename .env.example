# Copy this file to .env and fill in your values.
# .env is gitignored.

# --- DeepSeek (LLM for NPCs) ---
# Get an API key at https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# Optional overrides (defaults shown):
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat          # or deepseek-reasoner
# DEEPSEEK_TEMPERATURE=0.7
# DEEPSEEK_MAX_TOKENS=500
# DEEPSEEK_TIMEOUT=30

# --- Server ---
# HOST=127.0.0.1
# PORT=8000
# DEBUG=false

# --- Database ---
# DATABASE_URL=sqlite:///./game.db
# DATABASE_ECHO=false

# --- Auth / JWT ---
# REQUIRED in production. Generate with: python -c "import secrets;print(secrets.token_hex(32))"
JWT_SECRET=
# Optional overrides (defaults shown):
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=30
# STARTING_ROOM_ID=1
# MAX_CHARACTERS_PER_ACCOUNT=5
# PASSWORD_MIN_LENGTH=8
# Comma-separated usernames auto-granted admin at registration. (The very first
# account to register also becomes admin automatically.)
# ADMIN_USERNAMES=

# --- LLM cost control ---
# Per-account rate limits for NPC conversation (`talk` / POST /chat/npc). Each
# call hits DeepSeek. Set either to 0 to disable `talk` entirely. (defaults shown)
# TALK_RATE_PER_MIN=10
# TALK_RATE_PER_HOUR=120
# Global cap on mob smack-talk LLM lines, per room, per minute (distinct budget
# from player `talk`; canned barbs are used when over budget or DeepSeek is off).
# MOB_CHATTER_RATE_PER_MIN=8

# --- Real-time tile combat (Phase 1) ---
# COMBAT_TICK_SECONDS=0.3          # mob AI cadence (fast tick, separate from regen)
# MOVE_COOLDOWN_SECONDS=0.12       # per-player movement rate cap
# MOB_CHATTER_COOLDOWN_SECONDS=8   # per-mob smack-talk cooldown
# FOV_RADIUS=8                     # client field-of-view radius
